# ----------------------------------------
# 核心环境配置模板
# 复制此文件为 .env 并填入实际值
# ----------------------------------------

# Frontend API URL (Client-side fetch address)
# 本地开发默认为 http://localhost:8001。
# 部署到服务器时，请改为服务器的公网 IP 或域名，例如 http://123.45.67.89:8001
NEXT_PUBLIC_API_URL=http://localhost:8001

# Dify API Configuration
DIFY_API_URL=http://38.60.91.23/v1
DIFY_API_KEY=your_dify_api_key_here

# Gemini API Configuration (Google AI Studio)
# 官方默认读取的环境变量名为 GOOGLE_API_KEY
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# App Settings
DEBUG=True
